# .streamlit/secrets.toml — Template for Streamlit Community Cloud
# 
# On Streamlit Cloud, go to App Settings → Secrets and add:
#
# KAGGLE_USERNAME = "your_kaggle_username"
# KAGGLE_KEY = "your_kaggle_api_key"
#
# Get your API key from: https://www.kaggle.com/settings → API → Create New Token
# This will download kaggle.json — the username and key are in that file.
#
# DO NOT commit this file with real credentials. It is in .gitignore.
